rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Ogni utente può leggere/scrivere solo il proprio documento
    match /utenti/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    match /famiglie/{fid} {
      // Lettura del doc famiglia: serve a chi cerca il codice invito.
      // Il documento contiene solo nome, codice e uid dei membri.
      allow read: if request.auth != null;

      // Chiunque loggato può creare una famiglia (di cui è membro)
      allow create: if request.auth != null
        && request.auth.uid in request.resource.data.membri;

      // Aggiornabile dai membri, oppure da chi si sta aggiungendo
      // (l'update deve conservare tutti i membri esistenti)
      allow update: if request.auth != null && (
        request.auth.uid in resource.data.membri ||
        (
          request.resource.data.membri.hasAll(resource.data.membri) &&
          request.auth.uid in request.resource.data.membri
        )
      );

      // Lista spesa e dispensa: solo i membri della famiglia
      match /{sub}/{docId} {
        allow read, write: if request.auth != null
          && request.auth.uid in
             get(/databases/$(database)/documents/famiglie/$(fid)).data.membri;
      }
    }
  }
}
